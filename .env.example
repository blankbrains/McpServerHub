# ========================================
# MCP Server Hub — 必需配置
# 复制为 .env 并填写真实值
# cp .env.example .env
# ========================================

# --- 数据库（必需）---
MCP_HUB_DATABASE_URL=postgresql+asyncpg://用户名:密码@localhost:5432/mcp_hub

# --- JWT 密钥（必需，用随机字符串替换）---
MCP_HUB_SECRET=请替换为随机字符串

# --- GitHub OAuth（必需，在 https://github.com/settings/developers 注册）---
MCP_HUB_GITHUB_CLIENT_ID=你的GitHub_Client_ID
MCP_HUB_GITHUB_CLIENT_SECRET=你的GitHub_Client_Secret
MCP_HUB_GITHUB_REDIRECT_URI=http://localhost:3987/api/v1/auth/callback

# --- 服务配置（可选，有默认值）---
MCP_HUB_HOST=0.0.0.0
MCP_HUB_PORT=3987
MCP_HUB_CORS_ORIGINS=*
MCP_HUB_WORKERS=2
